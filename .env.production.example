# =============================================================================
# Production Environment Template — Railway
# =============================================================================
# Copy relevant values into your Railway service Variables dashboard.
# Railway does not use a .env file directly; this is a reference template.
#
# For Strapi Backend Service variables, use Railway "Reference Variables"
# to pull Postgres connection details automatically:
#   ${Postgres.PGHOST}, ${Postgres.PGPORT}, ${Postgres.PGUSER}, etc.
# =============================================================================

# ---------------------------------------------------------------------------
# Node Environment
# ---------------------------------------------------------------------------
NODE_ENV=production

# ---------------------------------------------------------------------------
# Strapi Backend
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=1337

DATABASE_CLIENT=postgres
# Use Railway reference variables for Postgres:
DATABASE_HOST=${Postgres.PGHOST}
DATABASE_PORT=${Postgres.PGPORT}
DATABASE_NAME=${Postgres.PGDATABASE}
DATABASE_USERNAME=${Postgres.PGUSER}
DATABASE_PASSWORD=${Postgres.PGPASSWORD}
DATABASE_SSL=true

# Generate with: openssl rand -base64 32
# APP_KEYS needs 4 comma-separated keys
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# Shared with Next.js — same value goes on both services. The Strapi backend
# POSTs to NEXT_REVALIDATE_URL with this secret in the body; Next.js verifies
# it in /api/revalidate. Generate once: openssl rand -base64 32
STRAPI_REVALIDATE_SECRET=replace-me

# Set on the Strapi backend service. Points at the Next.js frontend's
# /api/revalidate endpoint. Use the public Railway URL of the frontend service
# (or its internal *.railway.internal hostname). No trailing slash on the path.
# Example: https://nextjs-frontend-xxx.up.railway.app/api/revalidate
NEXT_REVALIDATE_URL=

# Public URL Strapi advertises to itself (admin email links, redirects, cookies).
# Required when running behind Railway's TLS-terminating reverse proxy so
# Strapi emits https:// URLs instead of internal http://.
STRAPI_PUBLIC_URL=https://your-strapi-backend.up.railway.app

# CORS — allow your frontend domain(s)
STRAPI_CORS_ORIGINS=https://yourdomain.com

# ---------------------------------------------------------------------------
# Next.js Frontend
# ---------------------------------------------------------------------------
# Must be the PUBLIC URL of your Strapi backend service
STRAPI_URL=https://your-strapi-backend.up.railway.app

# Strapi API token (read-only for frontend, create in Strapi Admin)
STRAPI_TOKEN=replace-with-strapi-api-token

# Public site URL (used for canonical URLs, OG tags, sitemap).
# Leave at the Railway-generated *.up.railway.app value until the custom
# domain (e.g. https://myorl.gr) is provisioned, then update this and redeploy.
NEXT_PUBLIC_SITE_URL=https://your-frontend.up.railway.app

# STRAPI_REVALIDATE_SECRET — set the SAME value declared above under
# "Strapi Backend"; both services read it. Listed here for visibility only.

# Google Places (optional)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ---------------------------------------------------------------------------
# CI/CD markers
# ---------------------------------------------------------------------------
DEPLOY_ENV=production

# ---------------------------------------------------------------------------
# Search (Meilisearch)
# ---------------------------------------------------------------------------
# Set to "false" in production; the Meilisearch infrastructure is dev-only.
SEARCH_ENABLED=false
NEXT_PUBLIC_SEARCH_ENABLED=false
