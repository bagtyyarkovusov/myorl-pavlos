#!/usr/bin/env sh

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)

# Regenerate shared types if Strapi schemas changed
if git diff --cached --name-only | grep -q "backend/src/api/page/content-types/page/schema.json"; then
  echo "[pre-commit] Schema changed — regenerating shared types..."
  (cd "$REPO_ROOT/packages/shared-types" && npm run generate)
  git add packages/shared-types/src/index.ts
fi

cd "$REPO_ROOT/frontend" && npx lint-staged
