# Strapi injection environment
#
# Copy to `.env` in this project root, fill in real values. You do not need to
# `export` variables manually: ``strapi_client.StrapiClient`` and related
# scripts load `.env` before reading ``STRAPI_URL`` / ``STRAPI_TOKEN`` (existing
# shell environment always wins over values from the file).

# Full origin of the Strapi REST API, no trailing slash.
STRAPI_URL=http://localhost:1337

# Strapi API token with create/update rights on api::page.page and
# api::tag.tag for both locales. Generate in Admin -> Settings -> API Tokens.
STRAPI_TOKEN=ecda1b3b1fdc697879308fa504fefa7cc19e0ba6e1571971c9ac4b8ad6662aa7ea4d144abc6363f35143c8a6dc1634ada71346ae34d1a033973840584dc76d47256b1c2bd014abf362872bec24014591035e334e696ecf9196d6656152fd9b0f1652fa922db3860200a7ab5d03aee5e5b39659cb3b5918273426a763ad547632

# Optional admin credentials used ONLY by migrate_files_assets.py to create
# Media Library folders (Strapi's folder API requires admin JWT, not an API
# token). If omitted, the script falls back to a flat upload at root.
STRAPI_ADMIN_EMAIL=
STRAPI_ADMIN_PASSWORD=

# Deployment environment target: `rehearsal` for the dev DB copy,
# `production` for the final cutover. The importer refuses to run against
# production without an explicit STRAPI_TARGET=production in the environment.
STRAPI_TARGET=rehearsal

# Optional: path to the pre-import snapshot so cleanup scripts can restore.
STRAPI_DB_SNAPSHOT=backend/.tmp/data.pre-import.db
