# Frontend environment — loaded by Next.js at build and runtime
#
# Copy to frontend/.env.local and fill in real values.

# Full origin of the Strapi REST API, no trailing slash.
STRAPI_URL=http://localhost:1337

# Strapi API token (read-only is sufficient for the frontend).
# Generate in Strapi Admin → Settings → API Tokens.
STRAPI_TOKEN=replace-with-a-readonly-strapi-token

# Public site URL (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for Strapi → Next.js revalidation webhook
STRAPI_REVALIDATE_SECRET=replace-with-a-long-random-secret
