# Frontend environment — loaded by Next.js at build and runtime
#
# Copy to frontend/.env.local and fill in real values.

# Full origin of the Strapi REST API, no trailing slash.
STRAPI_URL=http://localhost:1337

# Strapi API token (read-only is sufficient for the frontend).
# Generate in Strapi Admin → Settings → API Tokens.
STRAPI_TOKEN=replace-with-a-readonly-strapi-token

# Public site URL (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for Strapi → Next.js revalidation webhook
STRAPI_REVALIDATE_SECRET=replace-with-a-long-random-secret

# Full origin of the Meilisearch service used by the Search Index.
SEARCH_ENABLED=true
MEILI_HOST=http://localhost:57700
NEXT_PUBLIC_MEILI_HOST=http://localhost:57700
MEILI_MASTER_KEY=dev-master-key-do-not-use-in-prod
NEXT_PUBLIC_MEILI_SEARCH_KEY=dev-master-key-do-not-use-in-prod

# HMAC secret for Strapi → Next.js Search Index reindex webhooks.
STRAPI_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Contact form email delivery (Resend — free tier: 3,000 emails/month).
# Sign up at https://resend.com — no npm package required; we call the REST API directly.
RESEND_API_KEY=
# Inbox that receives contact form submissions (defaults to legacy clinic email).
CONTACT_TO_EMAIL=pavlos.tsolaridis@gmail.com
# Verified sender on your domain in production. For local dev, Resend allows:
#   MyORL Contact <onboarding@resend.dev>
CONTACT_FROM_EMAIL=MyORL Contact <onboarding@resend.dev>

# Bearer token that gates /admin routes (middleware-enforced).
# Requests must include Authorization: Bearer <ADMIN_TOKEN>.
ADMIN_TOKEN=

# Google Places API (New) — server only; used for review teasers (see frontend/src/lib/google/places.ts).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# Optional: public share / short Maps URL shown when linking “View on Google Maps”.
# GOOGLE_MAPS_LISTING_URL=
