# Server
HOST=0.0.0.0
PORT=1337

# Secrets (generate with: openssl rand -base64 32)
APP_KEYS=replace-with-four-random-keys
API_TOKEN_SALT=replace-with-random-value
ADMIN_JWT_SECRET=replace-with-random-value
TRANSFER_TOKEN_SALT=replace-with-random-value
JWT_SECRET=replace-with-random-value
ENCRYPTION_KEY=replace-with-random-value

# Strapi API (used by frontend and tools)
STRAPI_URL=http://localhost:1337
STRAPI_TOKEN=replace-with-a-strapi-api-token

# CORS (comma-separated frontend origins)
STRAPI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database — switch between sqlite (quick dev) and postgres (rehearsal/prod)
# SQLite (default — fast local dev, no Docker needed):
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# PostgreSQL (uncomment for rehearsal or production):
# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false
# DATABASE_SCHEMA=public

# Admin credentials
STRAPI_ADMIN_EMAIL=admin@admin.com
STRAPI_ADMIN_PASSWORD=replace-with-a-strong-password
