{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "description": ""
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "robotsNoindex": {
      "type": "boolean",
      "default": false
    },
    "robotsNofollow": {
      "type": "boolean",
      "default": false
    },
    "sitemapExclude": {
      "type": "boolean",
      "default": false
    },
    "sitemapPriority": {
      "type": "decimal"
    },
    "sitemapChangeFrequency": {
      "type": "enumeration",
      "enum": [
        "always",
        "hourly",
        "daily",
        "weekly",
        "monthly",
        "yearly",
        "never"
      ]
    },
    "schemaType": {
      "type": "string",
      "description": "Override the top-level structured data @type (e.g. MedicalWebPage, AboutPage). Defaults to WebPage."
    }
  }
}
