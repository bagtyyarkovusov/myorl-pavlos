{
  "kind": "collectionType",
  "collectionName": "video_entries",
  "info": {
    "singularName": "video-entry",
    "pluralName": "video-entries",
    "displayName": "Video Entry",
    "description": "Standalone medical video in the site video library"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "youtubeId": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "youtubeUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "categories": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "relatedArticle": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::page.page",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "legacyArticleUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
